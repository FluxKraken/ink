{
  "name": "@kraken/ink",
  "version": "0.5.01",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./react": "./react.ts",
    "./vite": "./vite.ts"
  },
  "imports": {
    "csstype": "npm:csstype@^3.2.3"
  },
  "types": "./mod.d.ts",
  "publish": {
    "include": [
      "README.md",
      "mod.ts",
      "mod.d.ts",
      "react.ts",
      "vite.ts",
      "src/**/*.ts",
      "dist/**/*.js",
      "dist/**/*.d.ts"
    ],
    "exclude": [
      "!dist/",
      "!dist/**"
    ]
  },
  "tasks": {
    "build": "rm -rf dist && deno cache --node-modules-dir=auto npm:@types/node@^22.10.2 && deno run --node-modules-dir=auto -A npm:typescript/bin/tsc -p tsconfig.json",
    "test": "deno test --node-modules-dir=auto -A vite_test.ts"
  }
}
